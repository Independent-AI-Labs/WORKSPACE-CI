# Copy to .env and edit (gitignored). Loaded by Makefile via -include .env
#
# Cloudflare: no VM tunnel wrapper; cloudflared called directly via CLOUDFLARED_BIN.

# Path to cloudflared binary (required if not in CI .boot-linux/bin)
CLOUDFLARED_BIN=/path/to/cloudflared
TUNNEL_CONFIG=cloudflare/config.yml

# Cloudflare API (verify: curl -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" \
#   https://api.cloudflare.com/client/v4/accounts/$CLOUDFLARE_ACCOUNT_ID/tokens/verify)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Tunnel run token (optional; use instead of cloudflare/credentials.json + config tunnel id)
# TUNNEL_TOKEN=

WIKI_TUNNEL_HOSTNAME=workspaceguardrails.com
WIKI_TUNNEL_NAME=workspace-ci-wiki

# Tunnel origin = wiki prod nginx (must match cloudflare ingress service URL)
# WIKI_TUNNEL_ORIGIN=https://127.0.0.1:443

# Wiki prod ports (optional)
# WIKI_HTTP_PORT=80
# WIKI_HTTPS_PORT=443

# CORS for wiki API (auto-appends https://$WIKI_TUNNEL_HOSTNAME if unset)
# ALLOWED_ORIGINS=https://localhost,https://127.0.0.1,https://workspaceguardrails.com