# Copy to .env and edit (gitignored). Loaded by Makefile via -include .env
#
# Cloudflare: no VM tunnel wrapper; cloudflared called directly via CLOUDFLARED_BIN.

# Optional: override cloudflared path. If unset, Makefile walks up from CI for
# $(BOOT_NAME)/bin/cloudflared, then falls back to PATH.
# CLOUDFLARED_BIN=/path/to/cloudflared
TUNNEL_CONFIG=cloudflare/config.yml

# Cloudflare API (verify: curl -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" \
#   https://api.cloudflare.com/client/v4/user/tokens/verify)
# TLS issuance (make wiki-tls-issue): Zone -> DNS -> Edit on LETSENCRYPT_CLOUDFLARE_ZONE
# Tunnel ingress sync (make wiki-tunnel-deploy): Account -> Cloudflare One Connectors -> Edit
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Tunnel run token (optional; use instead of cloudflare/credentials.json + config tunnel id)
# TUNNEL_TOKEN=

WIKI_TUNNEL_HOSTNAME=wiki.example.com
WIKI_TUNNEL_NAME=workspace-ci-wiki

# Tunnel origin = wiki prod nginx (must match cloudflare ingress service URL)
# WIKI_TUNNEL_ORIGIN=https://127.0.0.1:8443

# Wiki prod ports (optional; defaults are unprivileged, no root)
# WIKI_HTTP_PORT=8080
# WIKI_HTTPS_PORT=8443
# WIKI_TUNNEL_ID=<cloudflare-tunnel-uuid>  # required for ingress sync on deploy

# Let's Encrypt TLS (DNS-01 via Cloudflare; make wiki-tls-issue)
LETSENCRYPT_EMAIL=ops@example.com
# LETSENCRYPT_STAGING=1          # 1 = Let's Encrypt staging CA (test first)
# LETSENCRYPT_CLOUDFLARE_ZONE=example.com  # apex zone; defaults to WIKI_TUNNEL_HOSTNAME
WIKI_TLS_MODE=letsencrypt        # letsencrypt | self-signed | auto
# WIKI_TLS_DIR=cloudflare/certs/wiki.example.com
# WIKI_TLS_CN=wiki.example.com   # nginx server_name + self-signed CN; defaults to WIKI_TUNNEL_HOSTNAME

# CORS for wiki API (auto-appends https://$WIKI_TUNNEL_HOSTNAME if unset)
# ALLOWED_ORIGINS=https://localhost,https://127.0.0.1,https://wiki.example.com

# Home landing carousel at / (catalogue stays at /projects). Same as web/grafana.env.example for dev.
WIKI_HOME_LANDING_ENABLED=true