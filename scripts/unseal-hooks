#!/usr/bin/env bash
# unseal-hooks [consumer_dir]
#
# (sudo) Remove the immutable flag from the generated native git hooks in a
# consumer repo's .git/hooks/ so generate-hooks can rewrite them (hooks stay
# root-owned). Re-lock with lock-hooks afterwards. Checklist-style: skips
# already-unsealed hooks.
set -euo pipefail

_CI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/ci.sh
if ! source "$_CI_ROOT/lib/ci.sh"; then
    echo "ERROR: failed to source $_CI_ROOT/lib/ci.sh" >&2
    exit 1
fi

if [[ "$(id -u)" != "0" ]]; then
    ci_fail "unseal-hooks must run as root: sudo make -C projects/CI unseal-hooks"
    exit 1
fi

ci_acquire_deploy_lock

_consumer="${1:-}"
if [[ -z "$_consumer" ]]; then
    ci_fail "usage: unseal-hooks <consumer_dir>"
    exit 1
fi
_consumer="$(cd "$_consumer" && pwd)"
_hooks_dir="$_consumer/.git/hooks"

ci_info "Unsealing generated hooks in $_consumer"

_marker="AUTO-GENERATED by"
_unsealed=0
_skipped=0
for _stage in pre-commit commit-msg pre-push; do
    _hook="$_hooks_dir/$_stage"
    [[ -f "$_hook" ]] || continue
    if ! grep -q "$_marker" "$_hook"; then
        ci_info "  [skip]     $_stage (not generated by generate-hooks)"
        continue
    fi
    if [[ "$(ci_platform_name)" == "darwin" ]]; then
        if [[ "$(stat -f '%Sf' "$_hook")" == *uchg* ]]; then
            chflags nouchg "$_hook"
            echo "  [unsealed] $_stage"
            _unsealed=$((_unsealed + 1))
        else
            echo "  [already]  $_stage"
            _skipped=$((_skipped + 1))
        fi
        continue
    fi
    _attrs="$(lsattr -d "$_hook")"
    if [[ "${_attrs%% *}" == *i* ]]; then
        chattr -i "$_hook"
        echo "  [unsealed] $_stage"
        _unsealed=$((_unsealed + 1))
    else
        echo "  [already]  $_stage"
        _skipped=$((_skipped + 1))
    fi
done

# Hand the hooks dir and generated hooks to the invoking user so
# generate-hooks can rewrite them (lock-hooks re-roots everything).
_owner="${SUDO_UID:-0}:${SUDO_GID:-0}"
if [[ "$_owner" != "0:0" ]]; then
    for _stage in pre-commit commit-msg pre-push; do
        _hook="$_hooks_dir/$_stage"
        if [[ -f "$_hook" ]] && grep -q "$_marker" "$_hook"; then
            chown "$_owner" "$_hook"
        fi
    done
    chown "$_owner" "$_hooks_dir"
fi

if [[ $_unsealed -eq 0 ]]; then
    ci_pass "unseal-hooks: nothing sealed, nothing to do"
else
    ci_pass "unseal-hooks: unsealed $_unsealed hook(s); re-lock with lock-hooks after regenerating"
fi
