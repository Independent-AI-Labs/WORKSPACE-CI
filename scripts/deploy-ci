#!/usr/bin/env bash
# deploy-ci: promote WORKSPACE-CI (agent working repo) to the locked
# projects/CI deployment that every consumer repo's hooks source live.
#
# Security model (SECURITY-AUDIT-2026-07-18-EXEMPTION-TAMPERING §4.3):
#   - projects/CI is sourced live by generated hooks in every consumer
#     repo, so an agent-writable projects/CI lets the agent rewrite the
#     checks that gate its own commits. All CI development therefore
#     happens in projects/WORKSPACE-CI; this script (root only) is the
#     ONLY promotion path.
#   - The deployment consumes upstream (origin/main) exclusively. Local
#     commits that were never pushed are NOT deployed: hook-sourced code
#     must have server-side provenance.
#   - After sync, every git-tracked file is chowned root:root. Untracked
#     runtime trees (.venv, .boot-linux, node_modules, .next, .local,
#     uv caches) stay agent-owned so `uv run` / node / next dev inside
#     hooks keep working without root.
#
# Operator: sudo --preserve-env=HOME,SSH_AUTH_SOCK make deploy-ci
set -euo pipefail

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_WORK_REPO="$(cd "$_SCRIPT_DIR/.." && pwd)"
_PROJECTS_ROOT="$(cd "$_WORK_REPO/.." && pwd)"
_DEPLOY_DIR="$_PROJECTS_ROOT/CI"
_BRANCH="${DEPLOY_CI_BRANCH:-main}"

log_info() { printf '\033[0;32m[INFO]\033[0m %s\n' "$*"; }
log_warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$*"; }
log_error() { printf '\033[0;31m[ERROR]\033[0m %s\n' "$*" >&2; }

if [[ $EUID -ne 0 ]]; then
    log_error "deploy-ci must run as root: sudo --preserve-env=HOME,SSH_AUTH_SOCK make deploy-ci"
    exit 1
fi

if [[ "$_WORK_REPO" == "$_DEPLOY_DIR" ]]; then
    log_error "refusing to deploy from inside $_DEPLOY_DIR itself"
    log_error "run deploy-ci from the WORKSPACE-CI working repo"
    exit 1
fi

_remote="$(git -C "$_WORK_REPO" remote get-url origin)"

# 1. Ensure the deployment clone exists (from upstream, never copied
#    from the working repo: provenance must be server-visible).
if [[ ! -d "$_DEPLOY_DIR/.git" ]]; then
    log_info "cloning $_remote -> $_DEPLOY_DIR"
    git clone --branch "$_BRANCH" "$_remote" "$_DEPLOY_DIR"
fi

# 2. Verify the working repo has no unpushed commits: deployment must
#    match origin exactly.
git -C "$_WORK_REPO" fetch origin "$_BRANCH" --quiet
_ahead="$(git -C "$_WORK_REPO" rev-list --count "origin/$_BRANCH..HEAD")"
if [[ "$_ahead" != "0" ]]; then
    log_error "WORKSPACE-CI has $_ahead unpushed commit(s); push first:"
    log_error "  git -C $_WORK_REPO push"
    exit 1
fi
if [[ -n "$(git -C "$_WORK_REPO" status --porcelain)" ]]; then
    log_error "WORKSPACE-CI working tree is dirty; commit or stash before deploy"
    exit 1
fi

# 3. Fast-forward the deployment clone to origin. Root-run git is not
#    guard-gated, but stay on ff-only semantics regardless.
log_info "syncing $_DEPLOY_DIR to origin/$_BRANCH"
git -C "$_DEPLOY_DIR" fetch origin --quiet
git -C "$_DEPLOY_DIR" checkout "$_BRANCH" --quiet
if ! git -C "$_DEPLOY_DIR" merge --ff-only "origin/$_BRANCH" --quiet; then
    log_error "$_DEPLOY_DIR cannot fast-forward to origin/$_BRANCH (diverged)"
    log_error "inspect manually; do not force"
    exit 1
fi
if [[ -n "$(git -C "$_DEPLOY_DIR" status --porcelain --untracked-files=no)" ]]; then
    log_error "$_DEPLOY_DIR has uncommitted tracked modifications; refusing to deploy over them"
    exit 1
fi

_deployed="$(git -C "$_DEPLOY_DIR" rev-parse HEAD)"
log_info "deployed commit: $_deployed"

# 4. Lock every git-tracked file to root. Untracked runtime trees are
#    deliberately skipped (see header).
_count=0
while IFS= read -r -d '' f; do
    [[ -e "$_DEPLOY_DIR/$f" && ! -L "$_DEPLOY_DIR/$f" ]] || continue
    chown root:root "$_DEPLOY_DIR/$f"
    _count=$((_count + 1))
done < <(git -C "$_DEPLOY_DIR" ls-files -z)
chown root:root "$_DEPLOY_DIR"
log_info "locked $_count tracked files to root:root"

# 5. Root-own the .git tree so the agent cannot retarget refs/config.
chown -R root:root "$_DEPLOY_DIR/.git"
log_info "locked .git to root:root"

log_info "deploy-ci complete: $_DEPLOY_DIR @ $_deployed (root-locked)"
log_warn "reminder: hook runtime trees (.venv, node_modules) stay agent-owned; run install targets from WORKSPACE-CI as usual"
