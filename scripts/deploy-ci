#!/usr/bin/env bash
# deploy-ci: promote WORKSPACE-CI (agent working repo) to the locked
# projects/CI deployment that every consumer repo's hooks source live.
#
# Security model (SECURITY-AUDIT-2026-07-18-EXEMPTION-TAMPERING §4.3):
#   - projects/CI is sourced live by generated hooks in every consumer
#     repo, so an agent-writable projects/CI lets the agent rewrite the
#     checks that gate its own commits. All CI development therefore
#     happens in projects/WORKSPACE-CI; this script (root only) is the
#     ONLY promotion path.
#   - The deployment consumes upstream (origin/main) exclusively. Local
#     commits that were never pushed are NOT deployed: hook-sourced code
#     must have server-side provenance.
#   - After sync, every git-tracked file is chowned root:root. Untracked
#     runtime trees (.venv, .boot-linux, node_modules, .next, .local,
#     uv caches) stay agent-owned so `uv run` / node / next dev inside
#     hooks keep working without root.
#
# Operator: sudo make deploy-ci
set -euo pipefail

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_WORK_REPO="$(cd "$_SCRIPT_DIR/.." && pwd)"
_PROJECTS_ROOT="$(cd "$_WORK_REPO/.." && pwd)"
_DEPLOY_DIR="$_PROJECTS_ROOT/CI"
_BRANCH="${DEPLOY_CI_BRANCH:-main}"

log_info() { printf '\033[0;32m[INFO]\033[0m %s\n' "$*"; }
log_warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$*"; }
log_error() { printf '\033[0;31m[ERROR]\033[0m %s\n' "$*" >&2; }

if [[ $EUID -ne 0 ]]; then
    log_error "deploy-ci must run as root: sudo make deploy-ci"
    exit 1
fi

# Root shells do not inherit the agent PATH; the CI helper scripts
# (unseal-exemptions/lock-exemptions) need uv from the workspace boot dir.
_WORKSPACE_ROOT="$(cd "$_PROJECTS_ROOT/.." && pwd)"
_BOOT_BIN="$_WORKSPACE_ROOT/.boot-linux/bin"
if [[ -x "$_BOOT_BIN/uv" ]]; then
    export PATH="$_BOOT_BIN:$PATH"
fi

# Git identity model: SSH transport runs ONLY as the work-repo owner
# (via runuser). The guard injects that user's provisioned deploy key
# (agent_identity.rs -> git-ssh-wrapper); root's git has no credential
# context by design. Consequence: no git command in this script ever
# touches the network as root. The deploy clone instead syncs from the
# work repo's freshly fetched origin ref over local transport, which
# keeps server-side provenance (the ref arrived from origin over SSH
# moments earlier in the same run, as the owner).
# Owner is resolved from the worktree dir, not .git: the guard's
# post-op lock root-owns .git even in the agent's working repo.
_REPO_OWNER="$(stat -c %U "$_WORK_REPO")"
_OWNER_HOME="$(getent passwd "$_REPO_OWNER" | cut -d: -f6)"
if [[ -z "$_REPO_OWNER" || -z "$_OWNER_HOME" || "$_REPO_OWNER" == "root" ]]; then
    log_error "cannot resolve non-root owner of $_WORK_REPO"
    exit 1
fi
log_info "git transport identity: $_REPO_OWNER (home $_OWNER_HOME)"
git_as_owner() {
    runuser -u "$_REPO_OWNER" -- env HOME="$_OWNER_HOME" \
        GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=safe.directory GIT_CONFIG_VALUE_0='*' \
        git "$@"
}
# Root-side git reads the deploy clone (whose .git flips between owner
# and root across runs); pin safe.directory explicitly instead of
# relying on ambient gitconfig.
git_as_root() {
    env GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=safe.directory GIT_CONFIG_VALUE_0='*' \
        git "$@"
}

if [[ "$_WORK_REPO" == "$_DEPLOY_DIR" ]]; then
    log_error "refusing to deploy from inside $_DEPLOY_DIR itself"
    log_error "run deploy-ci from the WORKSPACE-CI working repo"
    exit 1
fi

_remote="$(git_as_owner -C "$_WORK_REPO" remote get-url origin)"

# 1. Ensure the deployment clone exists (from upstream, never copied
#    from the working repo: provenance must be server-visible).
if [[ ! -d "$_DEPLOY_DIR/.git" ]]; then
    log_info "cloning $_remote -> $_DEPLOY_DIR"
    git_as_owner clone --branch "$_BRANCH" "$_remote" "$_DEPLOY_DIR"
fi

# 2. Verify the working repo has no unpushed commits: deployment must
#    match origin exactly.
git_as_owner -C "$_WORK_REPO" fetch origin "$_BRANCH" --quiet
_ahead="$(git_as_owner -C "$_WORK_REPO" rev-list --count "origin/$_BRANCH..HEAD")"
if [[ "$_ahead" != "0" ]]; then
    log_error "WORKSPACE-CI has $_ahead unpushed commit(s); push first:"
    log_error "  git -C $_WORK_REPO push"
    exit 1
fi
if [[ -n "$(git_as_owner -C "$_WORK_REPO" status --porcelain)" ]]; then
    log_error "WORKSPACE-CI working tree is dirty; commit or stash before deploy"
    exit 1
fi

# 3. Fast-forward the deployment clone to the origin ref the work repo
#    just fetched. Local transport: root never authenticates to SSH
#    (see identity model above); ff-only semantics regardless.
log_info "syncing $_DEPLOY_DIR to origin/$_BRANCH (via work repo refs)"
git_as_root -C "$_DEPLOY_DIR" fetch "$_WORK_REPO" \
    "+refs/remotes/origin/$_BRANCH:refs/remotes/origin/$_BRANCH" --quiet
git_as_root -C "$_DEPLOY_DIR" checkout "$_BRANCH" --quiet
if ! git_as_root -C "$_DEPLOY_DIR" merge --ff-only "origin/$_BRANCH" --quiet; then
    log_error "$_DEPLOY_DIR cannot fast-forward to origin/$_BRANCH (diverged)"
    log_error "inspect manually; do not force"
    exit 1
fi
if [[ -n "$(git_as_root -C "$_DEPLOY_DIR" status --porcelain --untracked-files=no)" ]]; then
    log_error "$_DEPLOY_DIR has uncommitted tracked modifications; refusing to deploy over them"
    exit 1
fi

_deployed="$(git_as_root -C "$_DEPLOY_DIR" rev-parse HEAD)"
log_info "deployed commit: $_deployed"

# 4. Lock every git-tracked file to root. Untracked runtime trees are
#    deliberately skipped (see header). Sealed exemption files are +i
#    immutable, so unseal first and reseal after verification.
bash "$_WORK_REPO/scripts/unseal-exemptions" "$_DEPLOY_DIR"
_count=0
_ls_tmp="$(mktemp)" || { log_error "mktemp failed"; exit 1; }
git_as_root -C "$_DEPLOY_DIR" ls-files -z > "$_ls_tmp"
while IFS= read -r -d '' f; do
    [[ -e "$_DEPLOY_DIR/$f" && ! -L "$_DEPLOY_DIR/$f" ]] || continue
    chown root:root "$_DEPLOY_DIR/$f"
    _count=$((_count + 1))
done < "$_ls_tmp"
rm -f "$_ls_tmp"
chown root:root "$_DEPLOY_DIR"
log_info "locked $_count tracked files to root:root"

# 5. Root-own the .git tree so the agent cannot retarget refs/config.
#    Generated hooks are +i (lock-hooks), so unseal first and re-lock
#    after verification.
bash "$_WORK_REPO/scripts/unseal-hooks" "$_DEPLOY_DIR"
chown -R root:root "$_DEPLOY_DIR/.git"
log_info "locked .git to root:root"

# 6. Enforce executable bits from the git index. chown preserves modes,
#    but a file that ever lost +x locally would deploy a hook git
#    does not flag; the index mode (100755) is the source of truth.
_exec_fixed=0
_lss_tmp="$(mktemp)" || { log_error "mktemp failed"; exit 1; }
git_as_root -C "$_DEPLOY_DIR" ls-files -s -z > "$_lss_tmp"
while IFS= read -r -d '' _entry; do
    _mode="${_entry%% *}"
    _f="${_entry#*$'\t'}"
    [[ "$_mode" == "100755" && -f "$_DEPLOY_DIR/$_f" && ! -x "$_DEPLOY_DIR/$_f" ]] || continue
    chmod 0755 "$_DEPLOY_DIR/$_f"
    _exec_fixed=$((_exec_fixed + 1))
done < "$_lss_tmp"
[[ "$_exec_fixed" -gt 0 ]] && log_warn "restored exec bit on $_exec_fixed file(s) from index modes"

# 7. Final integrity gate: the deployment must verify clean before any
#    consumer commit/push is allowed against it (guard ci_integrity).
_verify_fail=0
while IFS= read -r -d '' _entry; do
    _mode="${_entry%% *}"
    _f="${_entry#*$'\t'}"
    _p="$_DEPLOY_DIR/$_f"
    [[ -e "$_p" || -L "$_p" ]] || { log_error "verify: tracked file missing: $_f"; _verify_fail=1; continue; }
    [[ -L "$_p" ]] && continue
    _owner="$(stat -c '%u' "$_p")"
    [[ "$_owner" == "0" ]] || { log_error "verify: not root-owned: $_f (uid $_owner)"; _verify_fail=1; }
    if [[ "$_mode" == "100755" && ! -x "$_p" ]]; then
        log_error "verify: index 100755 but not executable: $_f"
        _verify_fail=1
    fi
done < "$_lss_tmp"
rm -f "$_lss_tmp"
[[ "$(stat -c '%u' "$_DEPLOY_DIR/.git")" == "0" ]] || { log_error "verify: .git not root-owned"; _verify_fail=1; }
_head="$(git_as_root -C "$_DEPLOY_DIR" rev-parse HEAD)"
_origin="$(git_as_root -C "$_DEPLOY_DIR" rev-parse refs/remotes/origin/"$_BRANCH")"
[[ "$_head" == "$_origin" ]] || { log_error "verify: HEAD != origin/$_BRANCH"; _verify_fail=1; }
if [[ "$_verify_fail" -ne 0 ]]; then
    log_error "deployment failed integrity verification; NOT declaring success"
    exit 1
fi
log_info "integrity verification passed"
bash "$_WORK_REPO/scripts/lock-exemptions" "$_DEPLOY_DIR"
bash "$_WORK_REPO/scripts/lock-hooks" "$_DEPLOY_DIR"

log_info "deploy-ci complete: $_DEPLOY_DIR @ $_deployed (root-locked)"
log_warn "reminder: hook runtime trees (.venv, node_modules) stay agent-owned; run install targets from WORKSPACE-CI as usual"
