#!/usr/bin/env bash
# lock-hooks [consumer_dir]
#
# (sudo) Root-lock the AUTO-GENERATED native git hooks in a consumer repo's
# .git/hooks/ (chown root:root, chmod 0755, chattr +i / uchg). Only hooks
# carrying the generate-hooks marker are claimed. Regeneration then requires
# unseal-hooks. Checklist-style: skips already-compliant hooks.
set -euo pipefail

_CI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/ci.sh
if ! source "$_CI_ROOT/lib/ci.sh"; then
    echo "ERROR: failed to source $_CI_ROOT/lib/ci.sh" >&2
    exit 1
fi

if [[ "$(id -u)" != "0" ]]; then
    ci_fail "lock-hooks must run as root: sudo make -C projects/CI lock-hooks"
    exit 1
fi

_consumer="${1:-}"
if [[ -z "$_consumer" ]]; then
    ci_fail "usage: lock-hooks <consumer_dir>"
    exit 1
fi
_consumer="$(cd "$_consumer" && pwd)"
_hooks_dir="$_consumer/.git/hooks"

ci_info "Locking generated hooks in $_consumer"

_marker="AUTO-GENERATED by"
_locked=0
_compliant=0
for _stage in pre-commit commit-msg pre-push; do
    _hook="$_hooks_dir/$_stage"
    [[ -f "$_hook" ]] || continue
    if ! grep -q "$_marker" "$_hook"; then
        ci_info "  [skip]     $_stage (not generated by generate-hooks)"
        continue
    fi
    _owner="$(stat -c '%U:%G %a' "$_hook" 2>&1 || stat -f '%Su:%Sg %Lp' "$_hook")"
    if [[ "$(ci_platform_name)" == "darwin" ]]; then
        _sealed="$(stat -f '%Sf' "$_hook")"
        [[ "$_sealed" == *uchg* ]] && _is_immutable=1 || _is_immutable=0
    else
        _attrs="$(lsattr -d "$_hook")"
        [[ "${_attrs%% *}" == *i* ]] && _is_immutable=1 || _is_immutable=0
    fi
    if [[ "$_owner" == "root:root 755" && $_is_immutable -eq 1 ]]; then
        echo "  [compliant] $_stage"
        _compliant=$((_compliant + 1))
        continue
    fi
    chown root:root "$_hook"
    chmod 0755 "$_hook"
    if [[ "$(ci_platform_name)" == "darwin" ]]; then
        chflags uchg "$_hook"
    else
        chattr +i "$_hook"
    fi
    echo "  [locked]    $_stage (was: $_owner)"
    _locked=$((_locked + 1))
done

# Re-root the hooks dir (guard steady state) so an agent cannot swap in
# replacement hook files between guard-mediated git operations.
chown root:root "$_hooks_dir"

if [[ $_locked -eq 0 ]]; then
    ci_pass "lock-hooks: $_compliant hook(s) compliant, nothing to do"
else
    ci_pass "lock-hooks: locked $_locked hook(s), $_compliant already compliant"
fi
