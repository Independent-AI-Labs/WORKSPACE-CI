#!/usr/bin/env bash
# reinstall-hooks: regenerate native git hooks, transparently handling the
# root-lock (sealed) cycle when hooks are immutable.
#
# Fast path: hooks not sealed -> plain generate-hooks (fresh-checkout case).
# Sealed path: sudo unseal-hooks -> generate-hooks (as the invoking user,
# never root) -> sudo lock-hooks. A trap guarantees re-locking even when
# generation fails, so hooks are never left unsealed.
#
# sudo is invoked per-step (never `sudo make`): only unseal/lock need root,
# generation stays a user operation. Interactive password prompt is allowed
# when no cached credentials exist (per operator decision).
#
# Test seams (CI_REINSTALL_* env vars) point the three steps at fakes so
# unit tests can assert cycle ordering without root.

set -euo pipefail

_CI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/ci.sh
if ! source "$_CI_ROOT/lib/ci.sh"; then
    echo "ERROR: failed to source $_CI_ROOT/lib/ci.sh" >&2
    exit 1
fi

_UNSEAL="${CI_REINSTALL_UNSEAL:-$_CI_ROOT/scripts/unseal-hooks}"
_LOCK="${CI_REINSTALL_LOCK:-$_CI_ROOT/scripts/lock-hooks}"
_GENERATE="${CI_REINSTALL_GENERATE:-$_CI_ROOT/scripts/generate-hooks}"
_MARKER="AUTO-GENERATED by"

_as_root() {
    if [[ "$(id -u)" -eq 0 ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

# _hooks_sealed <hooks_dir>: returns 0 if any generated hook is root-owned
# or immutable (sealed), 1 otherwise. CI_REINSTALL_SEALED=1/0 overrides
# detection (test seam: non-root tests cannot chown/chattr fixtures).
_hooks_sealed() {
    if [[ "${CI_REINSTALL_SEALED:-}" == "1" || "${CI_REINSTALL_SEALED:-}" == "yes" || "${CI_REINSTALL_SEALED:-}" == "true" ]]; then
        return 0
    fi
    if [[ "${CI_REINSTALL_SEALED:-}" == "0" || "${CI_REINSTALL_SEALED:-}" == "no" || "${CI_REINSTALL_SEALED:-}" == "false" ]]; then
        return 1
    fi
    local _hooks_dir="$1" _stage _hook _owner _attrs
    for _stage in pre-commit commit-msg pre-push; do
        _hook="$_hooks_dir/$_stage"
        [[ -f "$_hook" ]] || continue
        grep -q "$_MARKER" "$_hook" || continue
        _owner="$(stat -c '%U' "$_hook")"
        [[ "$_owner" == "root" ]] && return 0
        if [[ "$(ci_platform_name)" == "darwin" ]]; then
            [[ "$(stat -f '%Sf' "$_hook")" == *uchg* ]] && return 0
        else
            _attrs="$(lsattr -d "$_hook")"
            [[ "${_attrs%% *}" == *i* ]] && return 0
        fi
    done
    return 1
}

_relock_on_exit() {
    if [[ "${_unsealed:-0}" -eq 1 ]]; then
        if ! _as_root bash "${_LOCK}" "${_repo_root}"; then
            ci_fail "re-lock failed; hooks left unsealed"
        fi
    fi
}

main() {
    local _repo_root
    _repo_root="$(git rev-parse --show-toplevel)"

    if ! _hooks_sealed "$_repo_root/.git/hooks"; then
        ci_info "hooks not sealed: plain regeneration"
        bash "$_GENERATE"
        return $?
    fi

    ci_info "hooks are root-sealed: running unseal -> generate -> lock cycle"
    _unsealed=0
    # Deferred expansion: the trap must read _unsealed/_repo_root at EXIT
    # time, not at trap-definition time.
    trap '_relock_on_exit' EXIT

    _as_root bash "$_UNSEAL" "$_repo_root"
    _unsealed=1

    local _rc=0
    bash "$_GENERATE" || _rc=$?

    _as_root bash "$_LOCK" "$_repo_root"
    _unsealed=0

    if [[ "$_rc" -ne 0 ]]; then
        ci_fail "hook generation failed (rc=$_rc); hooks re-locked in previous state"
        return "$_rc"
    fi
    ci_pass "hooks regenerated and re-locked"
}

main "$@"
