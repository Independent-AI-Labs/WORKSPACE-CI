[Unit]
Description=workspace-ci Wiki - Next.js Dev Server (HMR)
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=__PROJECT_ROOT__
Environment="PATH=__PROJECT_ROOT__/node_modules/.bin:__NODE_BIN__:/usr/local/bin:/usr/bin:/bin"
Environment="WIKI_DEV_PORT=__DEV_PORT__"
Environment="WIKI_DEV_HOST=0.0.0.0"
ExecStart=__NODE__ scripts/dev-single.mjs
Restart=always
RestartSec=5
MemoryHigh=4G
MemoryMax=6G
LimitNOFILE=65536
StandardOutput=journal
StandardError=journal
SyslogIdentifier=wiki-ci-dev

[Install]
WantedBy=default.target
