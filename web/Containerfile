# workspace-ci Wiki production image.
# Build context: workspace projects root (parent of CI/).
#   podman build -f CI/web/Containerfile -t workspace-ci-wiki:prod <projects-root>

# -----------------------------------------------------------------------------
# Stage 1: regenerate wiki JSON data from CI sources
# -----------------------------------------------------------------------------
FROM docker.io/library/python:3.13-slim-bookworm AS extract

RUN set -eux \
    && echo "[wiki-extract] apt-get update" \
    && apt-get update \
    && echo "[wiki-extract] apt-get install packages" \
    && apt-get install -y --no-install-recommends cloc git curl ca-certificates \
    && echo "[wiki-extract] apt cleanup" \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/CI

COPY CI/pyproject.toml CI/uv.lock ./
COPY CI/ci ./ci
COPY CI/lib ./lib
COPY CI/scripts ./scripts
COPY CI/config ./config
COPY CI/Makefile ./
COPY CI/web/src/data ./web/src/data

ENV CI_WEB_DATA_DIR=/workspace/CI/web/src/data
ENV CI_CONFIG_DIR=/workspace/CI/config
ENV CI_PROJECT_ROOT=/workspace/CI
ENV UV_VERSION=0.11.23
# code-stats.json is copied from the repo above; the extract stage has no sibling
# git repos, so regenerate hook/script/swallow data only.
RUN set -eux \
    && echo "[wiki-extract] bootstrap uv" \
    && bash scripts/bootstrap-uv \
    && echo "[wiki-extract] uv sync" \
    && PATH="/workspace/CI/.boot-linux/bin:$$PATH" uv sync --frozen \
    && echo "[wiki-extract] extract hook sources" \
    && PATH="/workspace/CI/.boot-linux/bin:$$PATH" uv run python scripts/extract-hook-sources.py \
    && echo "[wiki-extract] extract script sources" \
    && PATH="/workspace/CI/.boot-linux/bin:$$PATH" uv run python scripts/extract-script-sources.py \
    && echo "[wiki-extract] extract swallow detectors" \
    && PATH="/workspace/CI/.boot-linux/bin:$$PATH" uv run python scripts/extract-swallow-source.py \
    && echo "[wiki-extract] done"

# -----------------------------------------------------------------------------
# Stage 2: build Next.js standalone bundle
# -----------------------------------------------------------------------------
FROM docker.io/library/node:24-bookworm AS build

ENV NODE_OPTIONS=--max-old-space-size=4096
ENV NEXT_TELEMETRY_DISABLED=1
ENV WORKSPACE_PROJECTS_ROOT=/workspace
ENV CHROME_BIN=/usr/bin/chromium

RUN set -eux \
    && echo "[wiki-build] apt-get update" \
    && apt-get update \
    && echo "[wiki-build] install chromium + poppler for prebuild" \
    && apt-get install -y --no-install-recommends chromium poppler-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY WORKSPACE-VM/README.md WORKSPACE-VM/Makefile ./WORKSPACE-VM/
COPY WORKSPACE-VM/res ./WORKSPACE-VM/res
COPY WORKSPACE-VM/.git/config ./WORKSPACE-VM/.git/config
COPY WORKSPACE-GUARD/config ./WORKSPACE-GUARD/config
COPY WORKSPACE-GUARD/README.md WORKSPACE-GUARD/Makefile ./WORKSPACE-GUARD/
COPY WORKSPACE-GUARD/res ./WORKSPACE-GUARD/res
COPY WORKSPACE-GUARD/.git/config ./WORKSPACE-GUARD/.git/config
COPY WORKSPACE-GATEWAY/README.md WORKSPACE-GATEWAY/Makefile ./WORKSPACE-GATEWAY/
COPY WORKSPACE-GATEWAY/res ./WORKSPACE-GATEWAY/res
COPY WORKSPACE-GATEWAY/.git/config ./WORKSPACE-GATEWAY/.git/config
COPY WORKSPACE-WEB-CONTENT/ ./WORKSPACE-WEB-CONTENT/
COPY CI/README.md CI/Makefile ./CI/
COPY CI/res ./CI/res
COPY CI/config ./CI/config
COPY CI/docs ./CI/docs
COPY CI/scripts ./CI/scripts
COPY CI/web ./CI/web
COPY --from=extract /workspace/CI/web/src/data ./CI/web/src/data

WORKDIR /workspace/CI/web
ENV CI_WIKI_PROD_BUILD=1
RUN set -eux \
    && echo "[wiki-build] checking inputs" \
    && test -f /workspace/CI/README.md \
    && test -f /workspace/WORKSPACE-WEB-CONTENT/landing-posts.yaml \
    && echo "[wiki-build] npm install" \
    && npm install \
    && echo "[wiki-build] npm run build" \
    && npm run build \
    && echo "[wiki-build] done"

# -----------------------------------------------------------------------------
# Stage 3: minimal runtime
# -----------------------------------------------------------------------------
FROM docker.io/library/node:24-bookworm-slim AS run

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV WORKSPACE_PROJECTS_ROOT=/workspace
ENV WORKSPACE_WEB_CONTENT_ROOT=/workspace/WORKSPACE-WEB-CONTENT

WORKDIR /workspace

COPY WORKSPACE-VM/README.md WORKSPACE-VM/Makefile ./WORKSPACE-VM/
COPY WORKSPACE-VM/res ./WORKSPACE-VM/res
COPY WORKSPACE-VM/.git/config ./WORKSPACE-VM/.git/config
COPY WORKSPACE-GUARD/config ./WORKSPACE-GUARD/config
COPY WORKSPACE-GUARD/README.md WORKSPACE-GUARD/Makefile ./WORKSPACE-GUARD/
COPY WORKSPACE-GUARD/res ./WORKSPACE-GUARD/res
COPY WORKSPACE-GUARD/.git/config ./WORKSPACE-GUARD/.git/config
COPY WORKSPACE-GATEWAY/README.md WORKSPACE-GATEWAY/Makefile ./WORKSPACE-GATEWAY/
COPY WORKSPACE-GATEWAY/res ./WORKSPACE-GATEWAY/res
COPY WORKSPACE-GATEWAY/.git/config ./WORKSPACE-GATEWAY/.git/config
COPY WORKSPACE-WEB-CONTENT/ ./WORKSPACE-WEB-CONTENT/
COPY CI/README.md CI/Makefile ./CI/
COPY CI/res ./CI/res
COPY CI/config ./CI/config
COPY CI/docs ./CI/docs
COPY CI/scripts ./CI/scripts

WORKDIR /workspace/CI/web

COPY --from=build /workspace/CI/web/public ./public
COPY --from=build /workspace/CI/web/.next/standalone ./
COPY --from=build /workspace/CI/web/.next/static ./.next/static
COPY --from=build /workspace/CI/web/branding.yaml ./branding.yaml
COPY --from=build /workspace/CI/web/content ./content
COPY --from=build /workspace/CI/web/src/data ./src/data

RUN mkdir -p data/feedback

EXPOSE 3000
CMD ["node", "server.js"]