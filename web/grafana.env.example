# Dev Grafana embeds use same-origin /grafana (proxied to loopback :3030 with auth headers).
# Leave GRAFANA_BASE_URL unset so URLs derive from the wiki request host (recommended).
# Only set this for special cases (e.g. remote Grafana):
# GRAFANA_BASE_URL=http://127.0.0.1:3030/grafana
# Home landing at / (catalogue stays at /projects). Omit or set false to show catalogue on /.
WIKI_HOME_LANDING_ENABLED=true