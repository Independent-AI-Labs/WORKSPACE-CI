{
  "name": "workspace-ci-wiki",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "node scripts/sync-logos.mjs && node scripts/fetch-web-documents.mjs && node scripts/sync-web-content.mjs && node scripts/prerender-landing-pdf-previews.mjs && next dev",
    "prebuild": "node scripts/sync-logos.mjs && node scripts/fetch-web-documents.mjs && node scripts/sync-web-content.mjs && node scripts/prerender-landing-pdf-previews.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.8",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/language": "6.12.4",
    "@codemirror/legacy-modes": "6.5.3",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "clsx": "2.1.1",
    "dompurify": "3.4.12",
    "fuse.js": "7.5.0",
    "isomorphic-dompurify": "2.36.0",
    "js-yaml": "4.3.0",
    "marked": "17.0.6",
    "mermaid": "11.16.0",
    "next": "16.2.10",

    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "4.3.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@next/bundle-analyzer": "16.2.10",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/dompurify": "3.0.5",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.5.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "remixicon": "4.9.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
